# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# local vehicle photo uploads (fallback when Supabase bucket unavailable)
/public/uploads/vehicles/*
!/public/uploads/vehicles/.gitkeep

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local

# FB session cookies (stored after first login)
/data/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel
.env*
